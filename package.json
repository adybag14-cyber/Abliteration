{
  "name": "abliteration-handbook",
  "private": true,
  "type": "module",
  "description": "Fetch scripts for upstream docs, Heretic pins, and HF model registry",
  "scripts": {
    "fetch:docs": "node scripts/fetch-docs.mjs",
    "fetch:docs:firefox": "node scripts/fetch-docs.mjs --firefox",
    "fetch:heretic": "node scripts/fetch-heretic-tools.mjs",
    "fetch:hf-models": "node scripts/fetch-hf-heretic-models.mjs",
    "fetch:hf-models:firefox": "node scripts/fetch-hf-heretic-models.mjs --firefox",
    "fetch:all": "node scripts/fetch-heretic-tools.mjs && node scripts/fetch-docs.mjs && node scripts/fetch-hf-heretic-models.mjs --firefox && node scripts/build-heretic-models-doc.mjs",
    "build:heretic-models-doc": "node scripts/build-heretic-models-doc.mjs",
    "validate": "node scripts/ralph-validate.mjs",
    "ralph": "node scripts/ralph-loop.mjs",
    "ralph:ci": "node scripts/ralph-loop.mjs --skip-fetch --max 1",
    "ralph:next": "node scripts/ralph-next-task.mjs",
    "ralph:turn-end": "node scripts/ralph-turn-end.mjs",
    "ralph:autostart": "node scripts/ralph-autostart.mjs",
    "ralph:autostart:stop": "node scripts/ralph-autostart-stop.mjs",
    "eval:stats": "node scripts/count-eval-prompts.mjs",
    "eval:jarvis-safe": "python scripts/filter-jarvis-eval.py"
  },
  "devDependencies": {
    "playwright": "^1.49.0"
  }
}